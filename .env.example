# =============================================================================
# CrescitechMD - Variaveis de Ambiente
# =============================================================================
# Copie este arquivo para .env.local e preencha os valores.
# Variaveis marcadas com [OBRIGATORIO] sao necessarias para o app funcionar.
# Variaveis marcadas com [OPCIONAL] tem fallback ou sao para features extras.

# -----------------------------------------------------------------------------
# Database (Supabase PostgreSQL)
# -----------------------------------------------------------------------------
# [OBRIGATORIO] Connection string via pooler (usado em runtime)
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres"

# [OBRIGATORIO] Connection string direta (usado para migrations/prisma cli)
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# -----------------------------------------------------------------------------
# NextAuth v5
# -----------------------------------------------------------------------------
# [OBRIGATORIO] URL base do site (sem barra final)
NEXTAUTH_URL="http://localhost:3000"

# [OBRIGATORIO] Secret para JWT (minimo 32 caracteres)
# Gerar com: openssl rand -base64 32
NEXTAUTH_SECRET=""

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------
# [OBRIGATORIO] Chave secreta (sk_test_... em dev, sk_live_... em producao)
STRIPE_SECRET_KEY=""

# [OBRIGATORIO] Chave publica (pk_test_... em dev, pk_live_... em producao)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# [OBRIGATORIO] Secret do webhook (whsec_...)
# Em dev: stripe listen --forward-to localhost:3000/api/webhooks/stripe
# Em producao: configurar no Stripe Dashboard > Webhooks
STRIPE_WEBHOOK_SECRET=""

# [OBRIGATORIO] IDs dos precos dos planos (criar no Stripe Dashboard > Products)
STRIPE_PRICE_BASIC=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_BUSINESS=""

# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------
# [OBRIGATORIO] API key do Resend (re_...)
RESEND_API_KEY=""

# [OPCIONAL] Remetente dos emails (fallback: CrescitechMD <onboarding@resend.dev>)
# Em producao: CrescitechMD <noreply@crescitechmd.com>
RESEND_FROM_EMAIL="CrescitechMD <onboarding@resend.dev>"

# [OPCIONAL] Email de destino do formulario de contato (fallback: contato@crescitechmd.com)
CONTACT_EMAIL="contato@crescitechmd.com"

# -----------------------------------------------------------------------------
# Vercel Blob (armazenamento de arquivos convertidos)
# -----------------------------------------------------------------------------
# [OBRIGATORIO] Token de acesso ao Vercel Blob
BLOB_READ_WRITE_TOKEN=""

# -----------------------------------------------------------------------------
# Docling External API (producao)
# -----------------------------------------------------------------------------
# [OPCIONAL] URL do microservico Docling (se vazio, usa subprocess local)
DOCLING_API_URL=""

# [OPCIONAL] API key compartilhada para autenticacao com o microservico
DOCLING_API_KEY=""

# [OPCIONAL] Comando Python para subprocess local (fallback: python no Win, python3 no Linux)
PYTHON_CMD=""

# -----------------------------------------------------------------------------
# Analytics (opcional)
# -----------------------------------------------------------------------------
# [OPCIONAL] Google Analytics 4 Measurement ID
NEXT_PUBLIC_GA_ID=""
